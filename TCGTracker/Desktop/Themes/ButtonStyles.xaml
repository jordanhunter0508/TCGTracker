<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Add Button -->
    <Style x:Key="AddButton" TargetType="Button">
        <Setter Property="Background" Value="#4CAF50"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16 8"/>
        <Setter Property="Margin" Value="10 0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#45A049"/>
            </Trigger>
            <!-- Pressed -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#388E3C"/>
            </Trigger>
            <!-- Disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#BDBDBD"/>
                <Setter Property="Foreground" Value="#EEEEEE"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Edit Button -->
    <Style x:Key="EditButtonDataGrid" TargetType="Button">
        <Setter Property="Content" Value="Edit"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1E88E5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6 2"/>
        <Setter Property="Margin" Value="5 2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#1565C0"/>
            </Trigger>
            <!-- Pressed -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Foreground" Value="#0D47A1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Delete Button -->
    <Style x:Key="DeleteButtonDataGrid" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#E53935"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6 2"/>
        <Setter Property="Margin" Value="5 2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#b71c1c"/>
            </Trigger>
            <!-- Pressed -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Foreground" Value="#5c0e0e"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Activate/Deactivate Button -->
    <Style x:Key="ActivateButtonDataGrid" TargetType="Button">
        <!-- Base Appearance -->
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="5,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <!-- Simple Template -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Triggers -->
        <Style.Triggers>

            <!-- ACTIVE = TRUE (Deactivate) -->
            <DataTrigger Binding="{Binding Active}" Value="True">
                <Setter Property="Content" Value="Deactivate"/>
                <Setter Property="Foreground" Value="#E53935"/>
                <Setter Property="Tag" Value="Deactivate"/>
            </DataTrigger>
            <!-- Hover -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="Tag" Value="Deactivate"/>
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="#b71c1c"/>
            </MultiTrigger>
            <!-- Pressed -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsPressed" Value="True"/>
                    <Condition Property="Tag" Value="Deactivate"/>
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="#5c0e0e"/>
            </MultiTrigger>

            <!-- ACTIVE = FALSE (Reactivate) -->
            <DataTrigger Binding="{Binding Active}" Value="False">
                <Setter Property="Content" Value="Reactivate"/>
                <Setter Property="Foreground" Value="#4CAF50"/>
                <Setter Property="Tag" Value="Reactivate"/>
            </DataTrigger>
            <!-- Hover -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="Tag" Value="Reactivate"/>
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="#388E3C"/>
            </MultiTrigger>
            <!-- Pressed -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsPressed" Value="True"/>
                    <Condition Property="Tag" Value="Reactivate"/>
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="#1c471e"/>
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!-- Cancel Button -->
    <Style x:Key="CancelButton" TargetType="Button">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16 8"/>
        <Setter Property="Margin" Value="10 0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>