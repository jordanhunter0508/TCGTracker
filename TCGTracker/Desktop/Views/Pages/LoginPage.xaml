<Page x:Class="Desktop.Views.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Desktop.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage" Loaded="Page_Loaded">

    <Grid>

        <Border Width="350" Padding="20" Background="White"
                CornerRadius="10" BorderBrush="LightGray" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="TCG Tracker Login" FontSize="24" FontWeight="Bold" 
                           Margin="0,0,0,20" HorizontalAlignment="Center"/>
                <TextBlock Text="You must have a valid system admin account to log into this application." 
                           TextWrapping="Wrap" Margin="20 0 20 10" FontSize="14" HorizontalAlignment="Center"/>

                <!-- Email -->
                <TextBlock Text="Email"/>

                <TextBox x:Name="txtEmail" Height="30" Margin="0,5,0,15" VerticalContentAlignment="Center"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <TextBlock Text="Password"/>

                <PasswordBox x:Name="pwdPassword" Height="30" Margin="0,5,0,15" VerticalContentAlignment="Center"
                             PasswordChanged="pwdPassword_PasswordChanged"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,0,0,10"
                           TextWrapping="Wrap"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="Log In" Width="100"  Margin="5" IsDefault="True"
                            Command="{Binding LogInCommand}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
