<Page x:Class="Desktop.Views.Pages.GameListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Desktop.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameListPage">
    
    <ScrollViewer>
        <Grid>
            <Border Style="{StaticResource BorderDataGrid}">
                <StackPanel>
                    
                    <!-- Game Header -->
                    <Grid Margin="5 0 10 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Games" Style="{StaticResource DataGridHeader}"/>

                        <Button Grid.Column="1" Content="Add a Game"
                                Style="{StaticResource AddButton}" VerticalAlignment="Center" 
                                Command="{Binding AddGameCommand}"/>
                    </Grid>
                
                    <!-- List of Games -->
                    <DataGrid ItemsSource="{Binding Games}" AutoGenerateColumns="False"
                              Style="{StaticResource ListViewDataGrid}" SelectedItem="{Binding SelectedGame}">

                        <DataGrid.Columns>

                            <!-- Game Related Columns -->
                            <DataGridTextColumn Header="Name" Width="*"
                                                Binding="{Binding Name}" ElementStyle="{StaticResource CenteredTextBlock}"/>
                            
                            <DataGridTextColumn Header="Publisher" Width="150"
                                                Binding="{Binding Publisher}" ElementStyle="{StaticResource CenteredTextBlock}"/>
                            
                            <DataGridTextColumn Header="Official Website" Width="2*"
                                                Binding="{Binding OfficialWebsite}" ElementStyle="{StaticResource CenteredTextBlock}"/>

                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding Active}" ElementStyle="{StaticResource CenteredCheckBox}"/>

                            <!-- Action Buttons -->
                            <DataGridTemplateColumn Width="Auto" MinWidth="75">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource EditButtonDataGrid}"
                                                    Command="{Binding DataContext.EditGameCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                            <Button Style="{StaticResource ActivateButtonDataGrid}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
